{
  "agents": {
    "defaults": {
      "workspace": "/data/workspace-agent",
      "model": {
        "primary": "openrouter/${OPENROUTER_MODEL}"
      }
    },
    "list": [
      {
        "id": "${AGENT_NAME}",
        "default": true
      }
    ]
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "paired",
      "allowFrom": []
    }
  },
  "cron": {
    "enabled": true,
    "sessionRetention": "24h"
  },
  "gateway": {
    "trustedProxies": ["127.0.0.1"]
  }
}
